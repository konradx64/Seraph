# ─────────────────────────────────────────────────
# Stage 1: Build seraph-agent (Rust)
# ─────────────────────────────────────────────────
FROM rust:1.88-alpine AS builder

RUN apk add --no-cache \
    cmake \
    g++ \
    make \
    musl-dev \
    openssl-dev \
    openssl-libs-static \
    perl \
    pkgconf

WORKDIR /build

COPY Cargo.toml Cargo.lock ./
COPY seraphd/Cargo.toml seraphd/Cargo.toml
COPY seraph-agent/Cargo.toml seraph-agent/Cargo.toml

# Build dependencies with dummy binaries so this layer can be cached.
RUN mkdir -p seraphd/src seraph-agent/src \
    && echo "fn main() {}" > seraphd/src/main.rs \
    && echo "fn main() {}" > seraph-agent/src/main.rs \
    && cargo build --release -p seraph-agent

COPY seraphd/ seraphd/
COPY seraph-agent/ seraph-agent/

RUN touch seraph-agent/src/main.rs && cargo build --release -p seraph-agent

# ─────────────────────────────────────────────────
# Stage 2: Minimal Alpine runtime
# ─────────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates libssl3 libgcc

RUN addgroup -S seraph \
    && adduser -S -G seraph seraph \
    && mkdir -p /var/lib/seraph-agent \
    && chown seraph:seraph /var/lib/seraph-agent

COPY --from=builder /build/target/release/seraph-agent /usr/local/bin/seraph-agent

WORKDIR /var/lib/seraph-agent

USER seraph
ENTRYPOINT ["seraph-agent", "--data-dir", "/var/lib/seraph-agent"]
